# Outlook AI Configuration
# Copy this to ~/.outlook-ai/.env and fill in your values

# === Microsoft (已有) ===
OUTLOOK_EMAIL=your_email@live.com
AZURE_CLIENT_ID=a9ba2144-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# === Ollama (已有) ===
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT=120

# === Notion (V2 新增) ===
NOTION_TOKEN=secret_xxxxxxxxxxxx
NOTION_DATABASE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# === 微信推送 (V2 新增) ===
PUSHPLUS_TOKEN=your_pushplus_token

# === Scan Settings (V2) ===
SCAN_DAYS=3
